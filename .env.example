# Supabase browser-safe values for apps/web-portal
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side only. Do not expose this in frontend code or NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-only-operations

# Optional deployment values
NEXT_PUBLIC_APP_URL=http://localhost:3000
